# Google Gemini LLM (required for workout generation)
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Strava OAuth2 (required for real athlete data)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:8080/api/strava/exchange

# Token encryption (optional - auto-generated if not set)
ENDURO_TOKEN_KEY=

# Persistent data directory (optional - defaults to ~/.enduro-coach)
# On Railway, set this to the volume mount path (e.g. /data) so encrypted
# profile and token files survive redeployments.
DATA_DIR=

# Ktor server (Railway injects PORT automatically in production)
PORT=8080
